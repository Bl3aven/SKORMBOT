BOT_TOKEN=your_bot_token_hereSERVER_ID=123456789012345678OWNER_ID=your_discord_user_id_here# Oxeegen AI (for /chat and conversation summaries)OXEEGEN_API_ENDPOINT=https://inference-04.oxeegen.com/v1OXEEGEN_API_KEY=your_oxeegen_api_keyOXEEGEN_MODEL=Oxee-flash# MOODBEAST image generation (/createimage)COMFYUI_IMAGE_API_ENDPOINT=https://inference.tournayre.ovh/v1COMFYUI_IMAGE_API_KEY=COMFYUI_IMAGE_MODEL=moodimageCOMFYUI_IMAGE_QUALITY=standardCOMFYUI_IMAGE_SIZE=1024x1024COMFYUI_IMAGE_EDIT_SIZE=autoCOMFYUI_IMAGE_STEPS=32COMFYUI_IMAGE_CFG=6.0COMFYUI_IMAGE_EDIT_DENOISE=0.35COMFYUI_IMAGE_EDIT_MAX_BYTES=12582912COMFYUI_IMAGE_TIMEOUT_SECONDS=900COMFYUI_IMAGE_PROMPT_ENHANCE_ENABLED=trueCOMFYUI_IMAGE_NEGATIVE_PROMPT=low quality, blurry, distorted, deformed, bad anatomy, watermark, text artifacts# MOODBEAST video generation (/createvideo)COMFYUI_VIDEO_API_ENDPOINT=https://inference.tournayre.ovh/v1COMFYUI_VIDEO_API_KEY=COMFYUI_VIDEO_MODEL=moodvideoCOMFYUI_VIDEO_TIMEOUT_SECONDS=7200COMFYUI_VIDEO_POLL_SECONDS=10COMFYUI_VIDEO_MAX_PROMPT_CHARS=6000COMFYUI_VIDEO_MAX_IMAGE_BYTES=25165824# Lavalink (Music)LAVALINK_HOST=lavalinkLAVALINK_PORT=2333LAVALINK_PASSWORD=change-meSPOTIFY_CLIENT_ID=your_spotify_client_idSPOTIFY_CLIENT_SECRET=your_spotify_client_secret# Moonshine STT (Voice recording transcription)# Model cache directory (mounted volume recommended)MOONSHINE_VOICE_CACHE=/app/data/moonshine_cache